# Copy this file to .env and fill in any overrides.
# Defaults shown here match the docker-compose setup.

# Polymarket API endpoints (public — no credentials needed)
GAMMA_API_BASE=https://gamma-api.polymarket.com
CLOB_API_BASE=https://clob.polymarket.com
DATA_API_BASE=https://data-api.polymarket.com

# Paper trading
TRADE_SIZE_USD=10.0
LEADER_REFRESH_INTERVAL_HOURS=6
PNL_CHECK_INTERVAL_MINUTES=15
MONITOR_POLL_INTERVAL_SECONDS=60

# Concurrency: number of parallel CLOB price-fetch workers
TRADE_WORKER_COUNT=8

# PostgreSQL (overridden by docker-compose for the app container)
DATABASE_URL=postgresql+asyncpg://poly:poly@localhost:5432/polymarket

# Logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
